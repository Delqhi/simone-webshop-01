# OpenDocs (frontend + server) — example environment
# Copy to .env (server) and .env.local (frontend) depending on your setup.

# -----------------------------
# Server (Express) — REQUIRED for real AI
# -----------------------------
PORT=3000

# NVIDIA
NVIDIA_API_KEY=__REPLACE_ME__
NVIDIA_BASE_URL=https://integrate.api.nvidia.com
NVIDIA_MODEL=moonshotai/kimi-k2.5

# API auth gating (recommended for prod)
# If set, all /api/* endpoints (except /api/health) require header: X-OpenDocs-Token
API_AUTH_TOKEN=__REPLACE_ME__

# CORS (optional, set in prod)
CORS_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# SSRF hardening for website analyze
WEBSITE_FETCH_TIMEOUT_MS=12000
WEBSITE_FETCH_MAX_BYTES=750000
WEBSITE_ALLOW_PRIVATE_IPS=false

# Supabase Postgres Provisioning (optional)
# Required for real database tables inside documents.
# Format: postgresql://postgres:password@localhost:54322/postgres
SUPABASE_DB_URL=
SUPABASE_DB_SCHEMA=public

# -----------------------------
# Frontend (Vite) — optional (Supabase sync)
# -----------------------------
VITE_API_AUTH_TOKEN=__MATCH_API_AUTH_TOKEN__

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -----------------------------
# Integrations (OpenClaw + n8n)
# -----------------------------
# OpenClaw (server-side only; never expose token to browser)
OPENCLAW_BASE_URL=
OPENCLAW_TOKEN=

# n8n (server-side integrations; planned)
N8N_BASE_URL=
N8N_API_KEY=
