# Core go-live env (minimal)
DATABASE_URL=postgresql://simone:CHANGE_ME@db.example.internal:5432/simone
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SITE_URL=https://YOUR_DOMAIN

# API/Web security
CORS_ALLOWLIST=https://YOUR_DOMAIN
JWT_REQUIRED=true
SUPPLIER_WEBHOOK_SECRET=CHANGE_ME_SUPPLIER_WEBHOOK_SECRET
INTERNAL_API_URL=https://api.YOUR_DOMAIN
# NEXT_PUBLIC_API_URL=https://api.YOUR_DOMAIN

# Infra
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Optional overrides (normally derived from SUPABASE_URL)
# SUPABASE_JWKS_URL=https://YOUR_PROJECT.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_ISSUER=https://YOUR_PROJECT.supabase.co/auth/v1
# SUPABASE_AUDIENCE=authenticated

# Stripe (required for production checkout)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Transactional mail + invoice (required for worker in production)
# Preferred: base64-encoded service account JSON, fallback: file path mount
GOOGLE_SERVICE_ACCOUNT_JSON_B64=BASE64_ENCODED_SERVICE_ACCOUNT_JSON
# GOOGLE_SERVICE_ACCOUNT_FILE=/run/secrets/google-service-account.json
GMAIL_DELEGATED_USER=info@um-24.de
GMAIL_SENDER_FROM="Simone Shop <info@um-24.de>"
GMAIL_API_BASE_URL=https://gmail.googleapis.com

# Billing data for invoice header (required)
BILLING_COMPANY_NAME=Simone Shop
BILLING_ADDRESS="Musterstrasse 1, 10115 Berlin, Deutschland"
BILLING_TAX_ID=12/345/67890
BILLING_VAT_ID=DE123456789
INVOICE_OUTPUT_DIR=/tmp/simone-invoices

# Optional automation bridge signature
N8N_WEBHOOK_URL=https://n8n.example.com/webhook/simone-events
N8N_SHARED_SECRET=change_me

# Smoke checks (after deploy)
API_BASE_URL=https://api.YOUR_DOMAIN
ADMIN_BEARER_TOKEN=<admin_jwt>

# Optional AI provider for /api/v1/ai/chat
OPENCODE_ZEN_API_KEY=oc_live_xxx
OPENCODE_ZEN_MODEL=grok-code
OPENCODE_ZEN_URL=https://api.opencode.ai/v1/chat/completions
